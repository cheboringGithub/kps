{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static HTTP Server",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    },
    {
      "name": "Node Static Server (serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "."],
      "port": 8080,
      "autoPort": true
    }
  ]
}
